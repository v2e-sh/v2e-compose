# Shared secrets for the v2e-compose stacks. Encrypt to produce the real file:
#   sops --encrypt secrets.sops.yaml.example > secrets.sops.yaml
# then `sops secrets.sops.yaml` to fill in the real values.

# --- Traefik / Cloudflare DNS-01 (COMPOSE-1) ---
# Scoped Cloudflare API token — Zone:Read + DNS:Edit (NOT the global key).
CF_DNS_API_TOKEN: "<your-scoped-cloudflare-token>"

# --- Authelia SSO (SSO-1) ---
# The 4 core scalar secrets ARE env-injected (docker compose reads them here); the
# per-client OIDC secrets go to the RP apps (Arcane/Grafana) as plaintext:
#   docker run --rm authelia/authelia:4.39.20 authelia crypto rand --length 64 --charset alphanumeric
AUTHELIA_SESSION_SECRET: "<64-char-random>"
AUTHELIA_STORAGE_ENCRYPTION_KEY: "<64-char-random>"
AUTHELIA_RESET_PASSWORD_JWT_SECRET: "<64-char-random>"
AUTHELIA_OIDC_HMAC_SECRET: "<64-char-random>"
ARCANE_OIDC_CLIENT_SECRET: "<pbkdf2 random password (plaintext side)>"
GRAFANA_OIDC_CLIENT_SECRET: "<pbkdf2 random password (plaintext side)>"
# NOTE: the RS256 issuer private key, the admin argon2id hash, and the pbkdf2 client
# hashes are NOT env values — they are rendered to config/secrets/ files by the
# Ansible role (roles/compose_stack), whose SOPS group_vars/all.sops.yaml is the
# authoritative secret source for the lab. This example serves the local make path
# and as a per-secret reference.

# --- Semaphore (COMPOSE-3) ---
SEMAPHORE_DB_PASS: "<random, e.g. openssl rand -base64 18>"
SEMAPHORE_ADMIN_PASSWORD: "<random, e.g. openssl rand -base64 15>"
SEMAPHORE_ACCESS_KEY_ENCRYPTION: "<random, e.g. openssl rand -base64 32 — rotating invalidates stored keys>"
SEMAPHORE_RUNNER_REG_TOKEN: "<random>"

# --- Arcane (COMPOSE-3) ---
ARCANE_ENCRYPTION_KEY: "<random, e.g. openssl rand -base64 32>"
ARCANE_JWT_SECRET: "<random, e.g. openssl rand -base64 32>"

# --- Observability (Grafana) ---
GRAFANA_ADMIN_PASSWORD: "<random>"
# Backup notification channel (#59) — Grafana's "critical-multi" contact point fans
# severity:critical alerts to Discord as well as ntfy, so the notification path
# survives ntfy itself being down. Also a hard `${VAR:?...}` in compose.yml.
GRAFANA_DISCORD_WEBHOOK_URL: "<https://discord.com/api/webhooks/...>"

# --- Vaultwarden ---
VAULTWARDEN_ADMIN_TOKEN: "<random — Vaultwarden /admin panel token>"

# --- Infra node (Technitium DNS) — not part of compose_stack_stacks on services,
# deployed separately on the infra host; kept here since it's the same SOPS file ---
TECHNITIUM_ADMIN_PASSWORD: "<random, e.g. openssl rand -base64 15 — console at :5380>"

# --- mullvad-exit (gluetun + tailscale) ---
# From the Mullvad account portal: WireGuard config -> generate -> take these from
# the downloaded .conf ([Interface] PrivateKey / Address). NOT the devices-page key.
MULLVAD_WIREGUARD_PRIVATE_KEY: "<wg-private-key>"
MULLVAD_WIREGUARD_ADDRESSES: "<10.x.x.x/32>"
# Reuse the lab's reusable Tailscale auth key (also used by the host tailscale role).
TAILSCALE_AUTHKEY: "<tskey-...>"
