# Non-secret config for the v2e-compose stacks. Copy to .env and edit (or let Ansible
# render it from group_vars in the automated flow). Secrets (CF_DNS_API_TOKEN, the
# semaphore/arcane keys below) live in secrets.sops.yaml, NOT here.
DOMAIN=v2e.sh                 # public zone (Cloudflare) — ACME + email
INTERNAL_DOMAIN=int.v2e.sh   # internal-only names (Technitium + Tailscale split-DNS)
ACME_EMAIL=you@example.com
CERT_RESOLVER=staging          # flip to `production` once staging issues cleanly

# --- semaphore stack (secrets; generate + keep in secrets.sops.yaml) ---
# SEMAPHORE_DB_PASS=                 # openssl rand -base64 18
# SEMAPHORE_ADMIN_PASSWORD=          # openssl rand -base64 15
# SEMAPHORE_ACCESS_KEY_ENCRYPTION=   # openssl rand -base64 32 (rotating invalidates stored keys)
# SEMAPHORE_RUNNER_REG_TOKEN=        # random

# --- arcane stack (secrets) ---
# ARCANE_ENCRYPTION_KEY=             # openssl rand -base64 32
# ARCANE_JWT_SECRET=                 # openssl rand -base64 32

# --- observability stack (secrets) ---
# GRAFANA_ADMIN_PASSWORD=            # random

# --- vaultwarden stack (secrets) ---
# VAULTWARDEN_ADMIN_TOKEN=           # random — Vaultwarden /admin panel token

# --- infra node stacks (Technitium DNS + RustDesk); secrets in secrets.sops.yaml ---
# TECHNITIUM_ADMIN_PASSWORD=          # openssl rand -base64 15  (console at :5380)
# NAME_SERVERS is optional (defaults to 1.1.1.1, 9.9.9.9)
