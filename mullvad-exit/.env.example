# Standalone / VPS use of the mullvad-exit stack. Copy to .env and fill in.
# In the LAB this file is not used — the compose_stack role renders these vars from
# SOPS (mullvad_wireguard_private_key, mullvad_wireguard_addresses, tailscale_authkey)
# into the shared .env. Keep real secrets out of git either way.

# --- Mullvad WireGuard (from the account portal's generated .conf) ---
MULLVAD_WIREGUARD_PRIVATE_KEY=   # [Interface] PrivateKey=...
MULLVAD_WIREGUARD_ADDRESSES=     # [Interface] Address=... e.g. 10.64.222.21/32

# --- Location (non-secret; leave empty for Mullvad default) ---
MULLVAD_SERVER_CITIES=           # e.g. Amsterdam
MULLVAD_SERVER_COUNTRIES=        # e.g. Netherlands

# --- Tailscale (reuse the lab's REUSABLE auth key) ---
TAILSCALE_AUTHKEY=
MULLVAD_EXIT_HOSTNAME=mullvad    # name shown in the Tailscale exit-node picker

TZ=UTC
